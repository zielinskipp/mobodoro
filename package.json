{
  "name": "mobodoro",
  "version": "1.0.0",
  "description": "Mobodoro is a mob programming Pomodoro timer built with TypeScript, Fastify, and WebSockets. It allows multiple clients to sync in real time, with unique session URLs and rotating mob order when a Pomodoro ends.",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "vitest",
    "test:ui": "vitest --ui",
    "build": "tsc",
    "dev": "tsx watch src/index.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "@vitest/ui": "^4.0.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "ws": "^8.19.0"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "fastify": "^5.7.4"
  }
}
